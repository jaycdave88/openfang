<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.momo.watchdog</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/momo/intent/workspaces/https-github/repo/repos/openfang/scripts/watchdog.sh</string>
    </array>
    <key>StartInterval</key>
    <integer>60</integer>
